<fonts-modification version="1">
    <family customizationType="new-named-family" name="tran-os-sans">
        <font style="normal" supportedAxes="wght">
            TOS_VF.ttf
            <axis tag="wdth" stylevalue="100" />
        </font>
        <font style="italic" supportedAxes="wght">
            TransSans_Italic.ttf
            <axis tag="wdth" stylevalue="100" />
        </font>
    </family>
    <family customizationType="new-locale-family" operation="prepend" lang="zh-Hans">
        <font weight="400" style="normal" supportedAxes="wght" fallbackFor="tran-os-sans">
            TransSans_SC.ttf
            <axis tag="wght" stylevalue="400" />
        </font>
    </family>
    <family customizationType="new-locale-family" operation="prepend" lang="und-Thai" variant="elegant">
        <font weight="400" style="normal" supportedAxes="wght" fallbackFor="tran-os-sans">
            TransSans_Thai.ttf
            <axis tag="wght" stylevalue="400" />
        </font>
    </family>
    <family customizationType="new-locale-family" operation="prepend" lang="und-Thai" variant="compact">
        <font weight="400" style="normal" supportedAxes="wght" fallbackFor="tran-os-sans">
            TransSans_Thai.ttf
            <axis tag="wght" stylevalue="400" />
        </font>
    </family>
</fonts-modification>

