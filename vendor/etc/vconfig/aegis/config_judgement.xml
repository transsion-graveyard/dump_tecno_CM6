        </event>
        <event relatedevent="SF_COMPOSITE" window="30000" unit="millisecond">
            <result code="0xffffff3e" desc="SF Composite  hung"/>
        </event>
        <event relatedevent="HWC_FENCE_HUNG" window="50000" unit="millisecond">
            <result code="0xffffff2b" desc="HWC Fence hung"/>
        </event>
    </rule>
