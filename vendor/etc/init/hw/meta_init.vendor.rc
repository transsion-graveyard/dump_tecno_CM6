#SATP: change tranfac file perms by fujia.chu 20250313 start
on post-fs-data
    chmod 0660 /mnt/vendor/persist/tranfac_sensor.properties
    chmod 0660 /mnt/vendor/persist/tranfacmode.db
    chmod 0660 /mnt/vendor/persist/oximeter.txt
#SATP: change tranfac file perms by fujia.chu 20250313 end
#SATP: change camera calibration file perms by huihang.zhou 20251030 start
on post-fs-data
    write /data/vendor/multicam/sat/data_wide_uwide.txt
    write /data/vendor/multicam/sat/data_tele_wide.txt
    chown root root /data/vendor/multicam/sat/data_wide_uwide.txt
    chown root root /data/vendor/multicam/sat/data_tele_wide.txt
    chmod 0666 /data/vendor/multicam/sat/data_wide_uwide.txt
    chmod 0666 /data/vendor/multicam/sat/data_tele_wide.txt
#SATP: change camera calibration file perms by huihang.zhou 20251030 end
