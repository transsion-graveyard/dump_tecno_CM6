#USD:add for rkp drm csr by jiayi.xiong start
on init
    write /proc/bootprof "widevine run mount+"
    mount overlay overlay /vendor/app/mcRegistry lowerdir=/vendor/app/mcRegistry:/apex/com.mediatek.oemcrypto/firmware/tee
    write /proc/bootprof "widevine run mount-"
#USD:add for rkp drm csr by jiayi.xiong end

#USD: add meta mode start P7 by shishan.zheng 20250408 start
import /vendor/etc/init/vendor.transsion.hardware.security.trancriticalparavfy@1.0-service.rc
#USD: add meta mode start P7 by shishan.zheng 20250408 end
on late-fs
    class_start early_hal

#USD:add custom factory reset by youyang.lin 20250529 start
#TRANSSION_START
on property:persist.vendor.tran.wipedata=1
    tran_factory_reset
#TRANSSION_END
#USD:add custom factory reset by youyang.lin 20250529 end

#USD: add meta autoshutdown by youyang.lin 20250529 start
service shutdown_usbdis /bin/sh -c "sleep 1800 && reboot -p"
    disabled
    seclabel u:r:shell:s0
    user system
on property:ro.bootmode=meta && property:vendor.usb.tran.state=disconnected
    write /proc/bootprof "META: start shutdown..."
    start shutdown_usbdis
on property:ro.bootmode=meta && property:vendor.usb.tran.state=connected
    write /proc/bootprof "META: stop shutdown..."
    stop shutdown_usbdis
#USD: add meta autoshutdown by youyang.lin 20250529 end

