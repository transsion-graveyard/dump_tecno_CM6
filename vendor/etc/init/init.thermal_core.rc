service thermal_core /vendor/bin/thermal_core
    class main
    socket thermal_socket stream 660 root system
    user root
    group system radio
    disabled

on charger
	setprop ro.vendor.mtk_thermal_kpoc 1

on property:ro.vendor.mtk_thermal_2_0=1
    start thermal_core

on property:sys.boot_completed=1
	write /sys/bus/platform/devices/soc:gpu-power-throttling/boot_notify 1
	write /sys/bus/platform/devices/soc:cpu-power-throttling/boot_notify 1
