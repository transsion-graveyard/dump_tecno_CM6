# Device initialization - executed during post-fs-data phase
on post-fs-data
    mkdir /data/vendor 0777 nfc nfc
    mkdir /data/vendor/nfc 0777 nfc nfc
    mkdir /data/vendor/nfc/param 0777 nfc nfc
    chmod 0660 /dev/pn553
    chown nfc nfc /dev/pn553

service vendor.nfc_hal_service /vendor/bin/hw/android.hardware.nfc2-service.nxp_w
    interface aidl android.hardware.nfc.INfc/default
    interface aidl vendor.nxp.nxpnfc_aidl.INxpNfc/default
    class hal
    user nfc
    group nfc drmrpc system
    disabled

