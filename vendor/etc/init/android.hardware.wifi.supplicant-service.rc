#NFBD:add tranSupplicant by yuguo.zhang 20241219 start
service wpa_supplicant /vendor/bin/hw/wpa_supplicant \
	-O/data/vendor/wifi/wpa/sockets -dd \
	-g@android:wpa_wlan0
	#   we will start as root and wpa_supplicant will switch to user wifi
	#   after setting up the capabilities required for WEXT
	#   user wifi
	#   group wifi inet keystore
	interface aidl android.hardware.wifi.supplicant.ISupplicant/default
	interface aidl vendor.transsion.hardware.wifi.tranSupplicant.ITranSupplicant/default
	class main
	socket wpa_wlan0 dgram 660 wifi wifi
	user root
	disabled
	oneshot
#NFBD:add tranSupplicant by yuguo.zhang 20241219 end
